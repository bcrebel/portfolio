---
import NewLayout from '../layouts/NewLayout.astro';
import CanvasBackground from '../components/new/CanvasBackground.astro';
import Navbar from '../components/new/Navbar.astro';
import Hero from '../components/new/Hero.astro';
import SectionHeader from '../components/new/SectionHeader.astro';
import SocialLinks from '../components/new/SocialLinks.astro';
---

<NewLayout>
	<CanvasBackground />
	<div class="content-wrapper">
		<Navbar />
		
		<Hero
			greetingBefore="Hi, I'm"
			greetingHighlight="Carron!"
			title="I build exceptional experiences for users and developers alike."
			descriptionBefore="I'm a T-shaped software engineer with deep expertise in web applications and a broad foundation across "
			descriptionHighlight="product design, design systems, and developer tooling"
			descriptionAfter=". My favorite projects start with curiosity—understanding how people work, then turning those insights into software that empowers everyone to do their best work."
			bullets={['Based in New Orleans']}
			showPoweredByOkra
			ctaHref="#work"
			ctaText="View My Work"
		/>

		<section id="work">
			<div class="container">
				<SectionHeader label="Work" title="Where I've Worked" />
				<div class="card">
					<div class="work-item">
						<div class="work-item-left">
							<h3>Mighty Acorn Digital</h3>
							<p class="work-company-desc">A digital consultancy that modernizes complex government benefit programs—stabilizing, automating, and accelerating delivery without disrupting live services.</p>
						</div>
						<div class="work-item-right">
							<div class="work-item-top">
								<p class="work-role">Lead Software Engineer</p>
								<p class="work-dates">Apr 2025 - Present</p>
							</div>
							<p class="work-detail">Built a Next.js/TypeScript educator certification portal for the Massachusetts Department of Early Education and Care, shipping data models, multi-step validated forms, and API integrations. Owned USWDS design-system theming and launched <a href="https://github.com/bcrebel/uswds-intellisense" class="work-link" target="_blank" rel="noopener noreferrer"><span class="link-text">USWDS IntelliSense</span><svg class="external-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg></a>, a VS Code extension surfacing utility classes and tokens.</p>
						</div>
					</div>
				</div>
				<div class="card">
					<div class="work-item work-item-nyt">
						<div class="work-item-left">
							<h3>New York Times Games</h3>
							<p class="work-company-desc">The New York Times' games studio behind Wordle, Spelling Bee, and The Crossword - daily puzzles played by millions of subscribers.</p>
						</div>
						<div class="work-item-right">
							<div class="work-item-top">
								<p class="work-role">Senior Software Engineer</p>
								<p class="work-dates">Jul 2018 - Apr 2024</p>
							</div>
							<p class="work-detail">Prototyped browser games in Vanilla JS and HTML Canvas, then productionized them in React with shared components, state management, and editor tooling. Ran cross-functional A/B tests that drove significant gains in registration and subscriptions.</p>
						</div>
					</div>
					<div class="nyt-carousel">
						<div class="nyt-hover-viewport">
							<div class="nyt-hover-track">
								<span class="nyt-slide-frame nyt-slide-leaderboard nyt-slide-leaderboard-1">
									<img src="/portfolio/nyt_leaderboard_desktop_1.png" alt="" loading="lazy" />
								</span>
								<span class="nyt-slide-frame nyt-slide-leaderboard nyt-slide-leaderboard-2">
									<img src="/portfolio/nyt_leaderboard_desktop_2.png" alt="" loading="lazy" />
								</span>
								<span class="nyt-slide-frame nyt-slide-leaderboard nyt-slide-leaderboard-3">
									<img src="/portfolio/nyt_leaderboard_desktop_3.png" alt="" loading="lazy" />
								</span>
								<img src="/portfolio/nyt-work.png" alt="" loading="lazy" />
								<span class="nyt-slide-frame nyt-slide-tiles">
									<img src="/portfolio/nyt_tiles_clip.gif" alt="" loading="lazy" />
								</span>
								<span class="nyt-slide-frame nyt-slide-wordle">
									<img src="/portfolio/nyt_wordle.gif" alt="" loading="lazy" />
								</span>
								<img src="/portfolio/nyt_vertex_clip.gif" alt="" loading="lazy" />
								<span class="nyt-slide-frame nyt-slide-leaderboard nyt-slide-leaderboard-1">
									<img src="/portfolio/nyt_leaderboard_desktop_1.png" alt="" loading="lazy" />
								</span>
								<span class="nyt-slide-frame nyt-slide-leaderboard nyt-slide-leaderboard-2">
									<img src="/portfolio/nyt_leaderboard_desktop_2.png" alt="" loading="lazy" />
								</span>
								<span class="nyt-slide-frame nyt-slide-leaderboard nyt-slide-leaderboard-3">
									<img src="/portfolio/nyt_leaderboard_desktop_3.png" alt="" loading="lazy" />
								</span>
								<img src="/portfolio/nyt-work.png" alt="" loading="lazy" />
								<span class="nyt-slide-frame nyt-slide-tiles">
									<img src="/portfolio/nyt_tiles_clip.gif" alt="" loading="lazy" />
								</span>
								<span class="nyt-slide-frame nyt-slide-wordle">
									<img src="/portfolio/nyt_wordle.gif" alt="" loading="lazy" />
								</span>
								<img src="/portfolio/nyt_vertex_clip.gif" alt="" loading="lazy" />
							</div>
						</div>
					</div>
				</div>
				<div class="card">
					<div class="work-item">
						<div class="work-item-left">
							<h3>Hearst Digital Media</h3>
							<p class="work-company-desc">A global media company publishing dozens of magazine brands across web and mobile, from Cosmopolitan to Esquire.</p>
						</div>
						<div class="work-item-right">
							<div class="work-item-top">
								<p class="work-role">Product Designer</p>
								<p class="work-dates">Jul 2015 - May 2018</p>
							</div>
							<p class="work-detail">Adapted style guides across multiple brands, refining layout, typography, and visual hierarchy. Defined user flows and motion with Sass, HTML/Twig, and Sketch, and built ES6 and Node.js tools to streamline and automate team workflows.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section id="connect">
			<div class="container">
				<SectionHeader label="Connect" title="Let's Work Together" />
				<SocialLinks
					items={[
						{ href: 'https://github.com/bcrebel', label: 'GitHub' },
						{ href: 'https://www.linkedin.com/in/carronwhite/', label: 'LinkedIn' },
						{ href: 'https://bsky.app/profile/carronwhite.bsky.social', label: 'Bluesky' },
						{ href: 'mailto:carronwhite@gmail.com', label: 'Email' },
					]}
				/>
			</div>
		</section>
	</div>
</NewLayout>
