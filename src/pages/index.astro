---
import NewLayout from '../layouts/NewLayout.astro';
import { Image } from 'astro:assets';
import me from '../../public/me.png';
import remoteLA from '../../public/remote-la.png';
import pt from '../../public/pt.png';
import fabfixe from '../../public/fabfixe.png';
import future from '../../public/future.png';
import CanvasBackground from '../components/new/CanvasBackground.astro';
import Navbar from '../components/new/Navbar.astro';
import Hero from '../components/new/Hero.astro';
import SectionHeader from '../components/new/SectionHeader.astro';
import Card from '../components/new/Card.astro';
import SocialLinks from '../components/new/SocialLinks.astro';
---

<NewLayout>
	<CanvasBackground />
	<div class="content-wrapper">
		<Navbar />
		
		<Hero
			greeting="Hi, I'm Carron."
			title="I'm a senior full-stack developer and solutions architect."
			description="I have been sharing my need for speed since 1998 when I started hacking on the internet. I help businesses build elegant, robust and scalable software with the best tools."
			ctaHref="#work"
			ctaText="View My Work"
		/>

		<section id="work">
			<div class="container">
				<SectionHeader label="Work" title="Where I've Worked" />
				<Card href="#">
					<div class="work-item">
						<div class="work-item-left">
							<h3>Mighty Acorn Digital</h3>
							<p class="work-company-desc">A nimble digital studio focused on product strategy, brand storytelling, and high-impact web experiences for growing teams.</p>
						</div>
						<div class="work-item-right">
							<div class="work-item-top">
								<p class="work-role">Lead Product Engineer</p>
								<p class="work-dates">Jan 2023 - Mar 2024</p>
							</div>
							<p class="work-detail">Collaborated across design and engineering to launch campaign microsites, improve CMS workflows, and ship polished frontend systems under tight timelines. Helped teams move from idea to launch faster with reusable UI building blocks and clearer technical handoff patterns.</p>
						</div>
					</div>
				</Card>
				<Card href="#">
					<div class="work-item">
						<div class="work-item-left">
							<h3>New York Times Games</h3>
							<p class="work-company-desc">Global payments infrastructure powering millions of businesses worldwide. Developer-first design platform handling billions in transactions.</p>
						</div>
						<div class="work-item-right">
							<div class="work-item-top">
								<p class="work-role">Design Systems</p>
								<p class="work-dates">Sep 2025 - Present</p>
							</div>
							<p class="work-detail">Building components, patterns, and tooling for Sail - Stripe's design system. The work that makes the UI layer hold up across one of the most complex product surfaces on the web.</p>
						</div>
					</div>
				</Card>
				<Card href="#">
					<div class="work-item">
						<div class="work-item-left">
							<h3>Hearst Digital Media</h3>
							<p class="work-company-desc">The largest platform for Lottie animations, providing tools and resources for motion designers and developers.</p>
						</div>
						<div class="work-item-right">
							<div class="work-item-top">
								<p class="work-role">Design Engineer</p>
								<p class="work-dates">Apr 2024 - Sep 2025</p>
							</div>
							<p class="work-detail">Spent a year and a half deep in the dotLottie format - building tooling for animation theming and state-driven interactivity. Enough to end up on stage at Figma Config talking about it.</p>
						</div>
					</div>
				</Card>
			</div>
		</section>

		<section id="skills">
			<div class="container">
				<SectionHeader title="Skills" />
				<div class="tags">
					<span class="tag">React</span>
					<span class="tag">TypeScript</span>
					<span class="tag">Node.js</span>
					<span class="tag">Express.js</span>
					<span class="tag">GraphQL</span>
					<span class="tag">Next.js</span>
					<span class="tag">Sass</span>
					<span class="tag">TailwindCSS</span>
					<span class="tag">MongoDB</span>
					<span class="tag">PostgreSQL</span>
					<span class="tag">Storybook</span>
				</div>
			</div>
		</section>

		<section id="projects">
			<div class="container">
				<SectionHeader label="Projects" title="Personal Projects & Experiments" />
				<div class="grid-2">
					<Card href="/portfolio/future" title="Future">
						<div class="description">An experiment exploring future-focused product concepts.</div>
						<div style="margin-top: 20px;">
							<Image src={future} alt="Future screenshot" />
						</div>
					</Card>
					<Card href="/portfolio/remote/" title="Remote from Louisiana">
						<div class="description">Remote community and resources from Louisiana.</div>
						<div style="margin-top: 20px;">
							<Image src={remoteLA} alt="Remote LA" />
						</div>
					</Card>
					<Card href="/portfolio/fabfixe/" title="Fabfixe">
						<div class="description">A small product experiment and brand concept.</div>
						<div style="margin-top: 20px;">
							<Image src={fabfixe} alt="FabFixe" />
						</div>
					</Card>
					<Card href="/portfolio/pt/" title="PrettyTendr">
						<div class="description">Visual design and prototyping explorations.</div>
						<div style="margin-top: 20px;">
							<Image src={pt} alt="PrettyTendr" />
						</div>
					</Card>
				</div>
			</div>
		</section>

		<section id="connect">
			<div class="container">
				<SectionHeader label="Connect" title="Let's Work Together" />
				<SocialLinks
					items={[
						{ href: 'https://github.com/bcrebel', label: 'GitHub' },
						{ href: 'https://www.linkedin.com/in/carronwhite/', label: 'LinkedIn' },
						{ href: 'https://bsky.app/profile/carronwhite.bsky.social', label: 'Bluesky' },
						{ href: 'mailto:carronwhite@gmail.com', label: 'Email' },
					]}
				/>
			</div>
		</section>

		<footer>
			<div class="container">Designed & developed with intention © 2025</div>
		</footer>
	</div>
</NewLayout>
