---
interface Props {
	href?: string;
	title?: string;
	meta?: string;
	description?: string;
}
const { href, title, meta, description }: Props = Astro.props;
---

<a href={href ?? '#'} class="card" aria-disabled={href ? undefined : 'true'}>
	{title && <h3>{title}</h3>}
	{meta && <div class="meta">{meta}</div>}
	{description && <div class="description">{description}</div>}
	<slot />
</a>


