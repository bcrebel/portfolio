<canvas id="canvas"></canvas>

<script>
	(() => {
		const canvas = document.getElementById('canvas');
		if (!canvas) return;
		const ctx = canvas.getContext('2d');

		let w, h, shapes = [];

		function resize() {
			w = canvas.width = window.innerWidth;
			h = canvas.height = window.innerHeight;
			if (shapes.length > 0) {
				init();
			}
		}

		const colors = ['#7cb87c', '#9ac89a', '#5ea65e', '#a8d4a8', '#6fb06f'];

		class Shape {
			constructor() {
				this.x = Math.random() * w;
				this.y = Math.random() * h;
				this.size = (Math.random() * 25 + 25) * (2 / 3);
				this.vx = (Math.random() - 0.5) * 0.5;
				this.vy = (Math.random() - 0.5) * 0.5;
				this.rotation = Math.random() * Math.PI * 2;
				this.rotationSpeed = (Math.random() - 0.5) * 0.015;
				this.color = colors[Math.floor(Math.random() * colors.length)];
				this.opacity = Math.random() * 0.2 + 0.15;
				this.seedSizes = [];
				for (let i = 0; i < 5; i++) {
					this.seedSizes.push(0.85 + Math.random() * 0.25);
				}
			}
			update() {
				this.x += this.vx;
				this.y += this.vy;
				this.rotation += this.rotationSpeed;
				if (this.x < -this.size) this.x = w + this.size;
				if (this.x > w + this.size) this.x = -this.size;
				if (this.y < -this.size) this.y = h + this.size;
				if (this.y > h + this.size) this.y = -this.size;
			}
			draw() {
				ctx.save();
				ctx.translate(this.x, this.y);
				ctx.rotate(this.rotation);
				const points = 20;
				const baseRadius = this.size / 2;
				ctx.beginPath();
				for (let i = 0; i <= points; i++) {
					const angle = (i / points) * Math.PI * 2;
					const wave = Math.sin(i * 5 / points * Math.PI * 2) * 0.15;
					const radius = baseRadius * (0.85 + wave);
					const x = Math.cos(angle) * radius;
					const y = Math.sin(angle) * radius;
					if (i === 0) {
						ctx.moveTo(x, y);
					} else {
						ctx.lineTo(x, y);
					}
				}
				ctx.closePath();
				ctx.fillStyle = this.color;
				ctx.globalAlpha = this.opacity;
				ctx.fill();
				ctx.globalAlpha = this.opacity * 2.5;
				const numSeeds = 5;
				for (let i = 0; i < numSeeds; i++) {
					const angle = (i / numSeeds) * Math.PI * 2 + Math.PI / 10;
					const seedDist = baseRadius * 0.45;
					const x = Math.cos(angle) * seedDist;
					const y = Math.sin(angle) * seedDist;
					const sizeVariation = this.seedSizes[i];
					ctx.save();
					ctx.translate(x, y);
					ctx.rotate(angle + Math.PI / 2);
					ctx.beginPath();
					ctx.ellipse(0, 0, this.size * 0.08 * sizeVariation, this.size * 0.12 * sizeVariation, 0, 0, Math.PI * 2);
					ctx.fill();
					ctx.restore();
				}
				ctx.restore();
			}
		}

		function init() {
			shapes = [];
			for (let i = 0; i < 12; i++) {
				shapes.push(new Shape());
			}
		}

		function animate() {
			ctx.clearRect(0, 0, w, h);
			shapes.forEach(shape => {
				shape.update();
				shape.draw();
			});
			requestAnimationFrame(animate);
		}

		window.addEventListener('resize', resize);
		resize();
		init();
		requestAnimationFrame(animate);
	})();
</script>


